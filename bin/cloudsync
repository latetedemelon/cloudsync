#!/usr/bin/env python3
"""
cloudsync: folder-routed sync and versioned backup to rclone remotes.

Reads /etc/cloudsync/mappings.yaml, dispatches each entry to either
`rclone sync` (mirror) or `restic` (versioned, deduplicated, encrypted).

Subcommands:
  run <id>         Run one mapping by id (with retry-on-failure)
  run-all          Run all mappings sequentially
  list             List configured mappings
  check            Validate config and sources
  status           Report last-run / last-success / next-fire for each mapping
  check-remote     Verify remote integrity (restic check / rclone check)
  metrics          Emit Prometheus-format metrics (textfile collector)
  setup-systemd    Generate per-mapping systemd service/timer/path units
"""

from __future__ import annotations

import argparse
import fcntl
import logging
import os
import re
import shutil
import stat
import subprocess
import sys
import tempfile
import time
from dataclasses import dataclass, field
from datetime import datetime, timezone
from pathlib import Path
from typing import Optional

try:
    import yaml
except ImportError:
    sys.stderr.write("ERROR: pyyaml is required. Install with: apt install python3-yaml\n")
    sys.exit(1)


__version__ = "0.4.0"

CONFIG_PATH = Path(os.environ.get("CLOUDSYNC_CONFIG", "/etc/cloudsync/mappings.yaml"))
RCLONE_CONFIG = Path(os.environ.get("RCLONE_CONFIG", "/etc/cloudsync/rclone.conf"))
SYSTEMD_DIR = Path("/etc/systemd/system")
RUNTIME_DIR = Path("/run/cloudsync")
STATE_DIR = Path(os.environ.get("CLOUDSYNC_STATE_DIR", "/var/lib/cloudsync"))

# Restic exit code for "repository does not exist".
RESTIC_EXIT_REPO_MISSING = 10

# Default retry schedule for transient failures (seconds).
DEFAULT_RETRY_BACKOFF = [60, 300, 1800]  # 1m, 5m, 30m

ID_RE = re.compile(r"^[a-z0-9][a-z0-9_-]{0,63}$")
CONTROL_CHARS_RE = re.compile(r"[\x00-\x1f\x7f]")

log = logging.getLogger("cloudsync")


# ---------- config model ----------

@dataclass
class Retention:
    keep_daily: int = 7
    keep_weekly: int = 4
    keep_monthly: int = 12
    keep_yearly: int = 0
    prune: str = "always"  # "always" | "never"


@dataclass
class Retry:
    max_attempts: int = 3
    backoff_seconds: list[int] = field(default_factory=lambda: list(DEFAULT_RETRY_BACKOFF))


@dataclass
class Hooks:
    # Each entry is a shell command string, run via /bin/sh -c.
    # pre_run failures abort the run; on_success/on_failure failures log a warning.
    pre_run: list[str] = field(default_factory=list)
    on_success: list[str] = field(default_factory=list)
    on_failure: list[str] = field(default_factory=list)


@dataclass
class Mapping:
    id: str
    source: Path
    destination: str
    mode: str  # "sync" | "backup"
    trigger: str = "scheduled"  # "realtime" | "scheduled" | "both"
    schedule: str = "daily"  # OnCalendar shortcut or full expression
    debounce: int = 30  # seconds for realtime debounce
    timeout: str = "6h"  # systemd TimeoutStartSec value
    password_file: Optional[Path] = None
    retention: Retention = field(default_factory=Retention)
    retry: Retry = field(default_factory=Retry)
    hooks: Hooks = field(default_factory=Hooks)
    rclone_flags: list[str] = field(default_factory=list)
    exclude: list[str] = field(default_factory=list)


class ConfigError(Exception):
    pass


def _require_safe(value: str, field_name: str, mapping_id: str) -> None:
    if CONTROL_CHARS_RE.search(value):
        raise ConfigError(
            f"mapping {mapping_id!r}: field {field_name!r} contains control characters"
        )


def _build_mapping(entry: dict) -> Mapping:
    if not isinstance(entry, dict):
        raise ConfigError(f"mapping entry is not a mapping: {entry!r}")
    if "id" not in entry:
        raise ConfigError(f"mapping missing required field 'id': {entry!r}")
    mid = entry["id"]
    if not isinstance(mid, str) or not ID_RE.match(mid):
        raise ConfigError(
            f"invalid mapping id {mid!r}: must match {ID_RE.pattern}"
        )
    for required in ("source", "destination"):
        if required not in entry:
            raise ConfigError(f"mapping {mid!r}: missing required field {required!r}")
    source = str(entry["source"])
    destination = str(entry["destination"])
    _require_safe(source, "source", mid)
    _require_safe(destination, "destination", mid)
    schedule = str(entry.get("schedule", "daily"))
    _require_safe(schedule, "schedule", mid)
    timeout = str(entry.get("timeout", "6h"))
    _require_safe(timeout, "timeout", mid)

    retention_raw = entry.get("retention") or {}
    if not isinstance(retention_raw, dict):
        raise ConfigError(f"mapping {mid!r}: retention must be a mapping")
    allowed = {f for f in Retention.__dataclass_fields__}
    unknown = set(retention_raw) - allowed
    if unknown:
        raise ConfigError(
            f"mapping {mid!r}: unknown retention keys: {sorted(unknown)}"
        )
    prune = retention_raw.get("prune", "always")
    if prune not in ("always", "never"):
        raise ConfigError(
            f"mapping {mid!r}: retention.prune must be 'always' or 'never'"
        )
    retention = Retention(**retention_raw)

    retry_raw = entry.get("retry") or {}
    if not isinstance(retry_raw, dict):
        raise ConfigError(f"mapping {mid!r}: retry must be a mapping")
    allowed_retry = {f for f in Retry.__dataclass_fields__}
    unknown_retry = set(retry_raw) - allowed_retry
    if unknown_retry:
        raise ConfigError(
            f"mapping {mid!r}: unknown retry keys: {sorted(unknown_retry)}"
        )
    max_attempts = int(retry_raw.get("max_attempts", 3))
    if max_attempts < 1:
        raise ConfigError(f"mapping {mid!r}: retry.max_attempts must be >= 1")
    backoff = retry_raw.get("backoff_seconds", list(DEFAULT_RETRY_BACKOFF))
    if not isinstance(backoff, list) or not all(isinstance(x, int) and x >= 0 for x in backoff):
        raise ConfigError(
            f"mapping {mid!r}: retry.backoff_seconds must be a list of non-negative ints"
        )
    retry = Retry(max_attempts=max_attempts, backoff_seconds=list(backoff))

    hooks_raw = entry.get("hooks") or {}
    if not isinstance(hooks_raw, dict):
        raise ConfigError(f"mapping {mid!r}: hooks must be a mapping")
    allowed_hooks = {f for f in Hooks.__dataclass_fields__}
    unknown_hooks = set(hooks_raw) - allowed_hooks
    if unknown_hooks:
        raise ConfigError(
            f"mapping {mid!r}: unknown hooks keys: {sorted(unknown_hooks)}"
        )
    hooks_kwargs: dict[str, list[str]] = {}
    for hook_name in allowed_hooks:
        raw = hooks_raw.get(hook_name, []) or []
        if not isinstance(raw, list) or not all(isinstance(x, str) for x in raw):
            raise ConfigError(
                f"mapping {mid!r}: hooks.{hook_name} must be a list of strings"
            )
        for cmd in raw:
            _require_safe(cmd, f"hooks.{hook_name}", mid)
        hooks_kwargs[hook_name] = list(raw)
    hooks = Hooks(**hooks_kwargs)

    return Mapping(
        id=mid,
        source=Path(source),
        destination=destination,
        mode=entry.get("mode", "sync"),
        trigger=entry.get("trigger", "scheduled"),
        schedule=schedule,
        debounce=int(entry.get("debounce", 30)),
        timeout=timeout,
        password_file=Path(entry["password_file"]) if entry.get("password_file") else None,
        retention=retention,
        retry=retry,
        hooks=hooks,
        rclone_flags=list(entry.get("rclone_flags", []) or []),
        exclude=list(entry.get("exclude", []) or []),
    )


def load_config(path: Path = CONFIG_PATH) -> tuple[dict, list[Mapping]]:
    if not path.exists():
        raise ConfigError(f"config not found: {path}")
    with open(path) as f:
        data = yaml.safe_load(f) or {}
    if not isinstance(data, dict):
        raise ConfigError(f"config root must be a mapping, got {type(data).__name__}")

    defaults = data.get("defaults", {}) or {}
    default_rclone_flags = list(defaults.get("rclone_flags", []) or [])
    default_excludes = list(defaults.get("exclude", []) or [])

    mappings: list[Mapping] = []
    for entry in data.get("mappings", []) or []:
        m = _build_mapping(entry)
        # Defaults go first so per-mapping flags can override.
        m.rclone_flags = default_rclone_flags + m.rclone_flags
        m.exclude = default_excludes + m.exclude
        mappings.append(m)
    return defaults, mappings


# ---------- locking ----------

def _acquire_run_lock(mapping_id: str):
    RUNTIME_DIR.mkdir(parents=True, exist_ok=True)
    lock_path = RUNTIME_DIR / f"{mapping_id}.lock"
    fh = open(lock_path, "w")
    try:
        fcntl.flock(fh.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        log.info("another cloudsync run for %s is in progress; exiting", mapping_id)
        fh.close()
        return None
    return fh


# ---------- state tracking ----------

def _now_iso() -> str:
    return datetime.now(timezone.utc).isoformat(timespec="seconds")


def _state_path(mapping_id: str, suffix: str) -> Path:
    return STATE_DIR / f"{mapping_id}.{suffix}"


def _write_state(mapping_id: str, suffix: str, content: str) -> None:
    try:
        STATE_DIR.mkdir(parents=True, exist_ok=True)
    except PermissionError:
        return  # no-op if state dir is inaccessible (e.g. non-root test run)
    path = _state_path(mapping_id, suffix)
    try:
        with tempfile.NamedTemporaryFile(
            mode="w", dir=str(STATE_DIR), prefix=f".{path.name}.", delete=False,
        ) as tmp:
            tmp.write(content)
            tmp_path = Path(tmp.name)
        os.replace(tmp_path, path)
    except OSError as e:
        log.warning("could not write state %s: %s", path, e)


def _read_state(mapping_id: str, suffix: str) -> Optional[str]:
    path = _state_path(mapping_id, suffix)
    try:
        return path.read_text().strip() or None
    except FileNotFoundError:
        return None
    except OSError:
        return None


def _clear_state(mapping_id: str, suffix: str) -> None:
    try:
        _state_path(mapping_id, suffix).unlink()
    except FileNotFoundError:
        pass
    except OSError:
        pass


def _mark_run_start(mapping_id: str) -> None:
    _write_state(mapping_id, "last-run", _now_iso() + "\n")


def _mark_run_success(mapping_id: str) -> None:
    _write_state(mapping_id, "last-success", _now_iso() + "\n")
    _clear_state(mapping_id, "last-error")
    _clear_state(mapping_id, "attempts")


def _mark_run_failure(mapping_id: str, err: str, attempt: int) -> None:
    _write_state(mapping_id, "last-error", f"{_now_iso()}\n{err}\n")
    _write_state(mapping_id, "attempts", f"{attempt}\n")


# ---------- retry loop ----------

def _format_error(e: BaseException) -> str:
    if isinstance(e, subprocess.CalledProcessError):
        return f"{type(e).__name__}: command {e.cmd!r} exited {e.returncode}"
    return f"{type(e).__name__}: {e}"


def _retry(m: Mapping, fn) -> None:
    """Run fn() with retry-on-failure using m.retry config.

    Catches any ``Exception`` (not just ``subprocess.CalledProcessError``) so
    deterministic errors like a missing password file are still recorded in
    the state files and surfaced to ``status`` / ``metrics`` / ``on_failure``
    hooks. Re-raises the last exception if all attempts fail.

    Backoff indexing: attempt N (1-indexed) uses ``backoff_seconds[N-1]``,
    clamped to the last element once N exceeds the list length.
    """
    last_exc: Optional[BaseException] = None
    for attempt in range(1, m.retry.max_attempts + 1):
        try:
            fn()
            return
        except Exception as e:
            last_exc = e
            _mark_run_failure(m.id, _format_error(e), attempt)
            if attempt >= m.retry.max_attempts:
                break
            idx = min(attempt - 1, len(m.retry.backoff_seconds) - 1)
            wait = m.retry.backoff_seconds[idx] if m.retry.backoff_seconds else 0
            returncode = getattr(e, "returncode", None)
            log.warning(
                "mapping %s: attempt %d/%d failed (%s); retrying in %ds",
                m.id, attempt, m.retry.max_attempts,
                f"exit {returncode}" if returncode is not None else type(e).__name__,
                wait,
            )
            if wait > 0:
                time.sleep(wait)
    assert last_exc is not None
    raise last_exc


# ---------- execution ----------

def run_sync(m: Mapping) -> None:
    # User-supplied flags come last so they override defaults (rclone is last-wins).
    cmd = [
        "rclone", "sync",
        "--config", str(RCLONE_CONFIG),
        "--verbose",
        "--transfers", "4",
        "--checkers", "8",
        "--stats", "30s",
        "--stats-one-line",
        str(m.source),
        m.destination,
    ]
    for pattern in m.exclude:
        cmd.extend(["--exclude", pattern])
    cmd.extend(m.rclone_flags)
    log.info("[sync] %s -> %s", m.source, m.destination)
    subprocess.run(cmd, check=True)


def run_backup(m: Mapping) -> None:
    if not m.password_file:
        raise ValueError(f"mapping {m.id}: backup mode requires password_file")
    if not m.password_file.exists():
        raise FileNotFoundError(f"mapping {m.id}: password file missing: {m.password_file}")

    env = os.environ.copy()
    env["RCLONE_CONFIG"] = str(RCLONE_CONFIG)
    env["RESTIC_PASSWORD_FILE"] = str(m.password_file)

    repo = f"rclone:{m.destination}"

    # Only initialize when restic explicitly reports "repository does not exist"
    # (exit code 10). Any other failure is a real error we should surface.
    check = subprocess.run(
        ["restic", "-r", repo, "cat", "config"],
        env=env, capture_output=True,
    )
    if check.returncode == RESTIC_EXIT_REPO_MISSING:
        log.info("[backup] initializing restic repo at %s", repo)
        subprocess.run(["restic", "-r", repo, "init"], env=env, check=True)
    elif check.returncode != 0:
        sys.stderr.write(check.stderr.decode("utf-8", errors="replace"))
        raise subprocess.CalledProcessError(
            check.returncode, check.args, check.stdout, check.stderr,
        )

    # Clear stale restic locks left behind by a previously killed or crashed
    # run. `restic unlock` (without --remove-all) is the safe form: it only
    # removes stale locks (process is dead AND lock is older than ~30 min);
    # exclusive locks held by a live restic process are left intact. Our
    # per-mapping flock already prevents two cloudsync runs racing here, so
    # this is defensive cleanup for SIGKILL / OOM / host-reboot scenarios.
    log.info("[backup] clearing any stale restic locks")
    subprocess.run(["restic", "-r", repo, "unlock"], env=env, check=False)

    cmd = ["restic", "-r", repo, "backup", str(m.source), "--tag", f"cloudsync:{m.id}"]
    for pattern in m.exclude:
        cmd.extend(["--exclude", pattern])
    log.info("[backup] %s -> %s", m.source, repo)
    subprocess.run(cmd, env=env, check=True)

    cmd = [
        "restic", "-r", repo, "forget",
        "--tag", f"cloudsync:{m.id}",
        "--keep-daily", str(m.retention.keep_daily),
        "--keep-weekly", str(m.retention.keep_weekly),
        "--keep-monthly", str(m.retention.keep_monthly),
        "--keep-yearly", str(m.retention.keep_yearly),
    ]
    if m.retention.prune == "always":
        cmd.append("--prune")
        log.info("[backup] applying retention policy (with prune)")
    else:
        log.info("[backup] applying retention policy (forget only, no prune)")
    subprocess.run(cmd, env=env, check=True)


def dispatch(m: Mapping) -> None:
    if m.mode == "sync":
        run_sync(m)
    elif m.mode == "backup":
        run_backup(m)
    else:
        raise ValueError(f"unknown mode: {m.mode}")


def _hook_env(m: Mapping, error: Optional[str] = None) -> dict:
    env = os.environ.copy()
    env.update({
        "CLOUDSYNC_MAPPING_ID": m.id,
        "CLOUDSYNC_MODE": m.mode,
        "CLOUDSYNC_SOURCE": str(m.source),
        "CLOUDSYNC_DESTINATION": m.destination,
        "CLOUDSYNC_TRIGGER": m.trigger,
    })
    if error is not None:
        env["CLOUDSYNC_ERROR"] = error
    return env


def _run_hooks(m: Mapping, kind: str, commands: list[str], fatal: bool,
               error: Optional[str] = None) -> None:
    if not commands:
        return
    env = _hook_env(m, error=error)
    for cmd in commands:
        log.info("[%s hook] %s: %s", kind, m.id, cmd)
        try:
            subprocess.run(["/bin/sh", "-c", cmd], env=env, check=True)
        except subprocess.CalledProcessError as e:
            if fatal:
                log.error("%s hook failed (exit %d); aborting run", kind, e.returncode)
                raise
            log.warning("%s hook failed (exit %d); continuing", kind, e.returncode)


def _run_locked(m: Mapping) -> None:
    lock = _acquire_run_lock(m.id)
    if lock is None:
        return
    try:
        _mark_run_start(m.id)
        _run_hooks(m, "pre_run", m.hooks.pre_run, fatal=True)
        try:
            _retry(m, lambda: dispatch(m))
        except Exception as e:
            _run_hooks(
                m, "on_failure", m.hooks.on_failure, fatal=False,
                error=_format_error(e),
            )
            raise
        _mark_run_success(m.id)
        _run_hooks(m, "on_success", m.hooks.on_success, fatal=False)
    finally:
        lock.close()


# ---------- subcommands ----------

def cmd_run(args) -> None:
    _, mappings = load_config()
    by_id = {m.id: m for m in mappings}
    if args.id not in by_id:
        log.error("unknown mapping id: %s", args.id)
        log.error("available: %s", ", ".join(sorted(by_id)))
        sys.exit(2)
    _run_locked(by_id[args.id])


def cmd_run_all(args) -> None:
    _, mappings = load_config()
    failed: list[str] = []
    succeeded: list[str] = []
    for m in mappings:
        try:
            _run_locked(m)
            succeeded.append(m.id)
        except subprocess.CalledProcessError as e:
            log.error("mapping %s failed: %s", m.id, e)
            failed.append(m.id)
        except Exception as e:
            log.error("mapping %s error: %s", m.id, e)
            failed.append(m.id)
    print(f"\nrun-all summary: {len(succeeded)} ok, {len(failed)} failed")
    if failed:
        print(f"failed: {', '.join(failed)}")
        sys.exit(1)


def cmd_list(args) -> None:
    _, mappings = load_config()
    if not mappings:
        print("(no mappings configured)")
        return
    w_id = max((len(m.id) for m in mappings), default=10)
    w_id = max(w_id, len("ID"))
    print(f"{'ID'.ljust(w_id)}  MODE    TRIGGER    SOURCE -> DESTINATION")
    print("-" * 80)
    for m in mappings:
        print(f"{m.id.ljust(w_id)}  {m.mode:<6}  {m.trigger:<9}  {m.source} -> {m.destination}")


# ---------- status ----------

def _parse_iso(s: Optional[str]) -> Optional[datetime]:
    if not s:
        return None
    s = s.splitlines()[0].strip()
    try:
        return datetime.fromisoformat(s)
    except ValueError:
        return None


def _humanize(ts: Optional[datetime], now: datetime) -> str:
    if ts is None:
        return "never"
    delta = now - ts
    secs = int(delta.total_seconds())
    if secs < 0:
        secs = -secs
        suffix = "from now"
    else:
        suffix = "ago"
    if secs < 60:
        return f"{secs}s {suffix}"
    if secs < 3600:
        return f"{secs // 60}m {suffix}"
    if secs < 86400:
        return f"{secs // 3600}h {suffix}"
    return f"{secs // 86400}d {suffix}"


def _systemd_next_fire(unit: str) -> Optional[datetime]:
    if not shutil.which("systemctl"):
        return None
    res = subprocess.run(
        ["systemctl", "show", unit,
         "--property=NextElapseUSecRealtime", "--value"],
        capture_output=True, text=True,
    )
    if res.returncode != 0:
        return None
    raw = res.stdout.strip()
    if not raw or raw == "0" or raw == "n/a":
        return None
    # systemd emits a human-readable timestamp, e.g. "Sun 2026-04-19 05:30:00 UTC"
    for fmt in ("%a %Y-%m-%d %H:%M:%S %Z", "%a %Y-%m-%d %H:%M:%S"):
        try:
            return datetime.strptime(raw, fmt).replace(tzinfo=timezone.utc)
        except ValueError:
            continue
    return None


def cmd_status(args) -> None:
    _, mappings = load_config()
    if not mappings:
        print("(no mappings configured)")
        return

    now = datetime.now(timezone.utc)
    rows = []
    any_failing = False
    for m in mappings:
        last_run = _parse_iso(_read_state(m.id, "last-run"))
        last_succ = _parse_iso(_read_state(m.id, "last-success"))
        last_err_raw = _read_state(m.id, "last-error")
        attempts_raw = _read_state(m.id, "attempts")
        attempts = int(attempts_raw.strip()) if attempts_raw and attempts_raw.strip().isdigit() else 0

        # A mapping is "failing" if its most recent run ended in error,
        # i.e. last-error is present and last-success (if any) predates it.
        last_err_ts = None
        if last_err_raw:
            last_err_ts = _parse_iso(last_err_raw)
        failing = (
            last_err_ts is not None
            and (last_succ is None or last_err_ts > last_succ)
        )
        if failing:
            any_failing = True

        next_fire = None
        if m.trigger in ("scheduled", "both"):
            next_fire = _systemd_next_fire(f"cloudsync-{m.id}.timer")

        state = "FAILING" if failing else ("ok" if last_succ else "-")
        rows.append({
            "id": m.id,
            "mode": m.mode,
            "trigger": m.trigger,
            "last_success": _humanize(last_succ, now),
            "last_run": _humanize(last_run, now),
            "next_fire": _humanize(next_fire, now) if next_fire else (
                "realtime" if m.trigger == "realtime" else "-"
            ),
            "state": state,
            "attempts": attempts,
        })

    widths = {k: max(len(k), max(len(str(r[k])) for r in rows)) for k in rows[0]}
    # Header
    header = "  ".join(k.upper().ljust(widths[k]) for k in
                       ("id", "mode", "trigger", "last_success", "last_run", "next_fire", "state"))
    print(header)
    print("-" * len(header))
    for r in rows:
        line = "  ".join(str(r[k]).ljust(widths[k]) for k in
                         ("id", "mode", "trigger", "last_success", "last_run", "next_fire", "state"))
        print(line)
        if r["state"] == "FAILING":
            err = _read_state(r["id"], "last-error")
            if err:
                # last-error file is "<iso>\n<message>\n"
                lines = err.strip().splitlines()
                msg = lines[1] if len(lines) > 1 else ""
                print(f"    last-error: {msg}  (consecutive attempts: {r['attempts']})")

    sys.exit(1 if any_failing else 0)


# ---------- check-remote ----------

def _check_remote_sync(m: Mapping) -> None:
    cmd = [
        "rclone", "check",
        "--config", str(RCLONE_CONFIG),
        "--size-only",  # fast: doesn't download/hash every file
        str(m.source), m.destination,
    ]
    for pattern in m.exclude:
        cmd.extend(["--exclude", pattern])
    log.info("[check-remote sync] %s <-> %s", m.source, m.destination)
    subprocess.run(cmd, check=True)


def _check_remote_backup(m: Mapping) -> None:
    if not m.password_file or not m.password_file.exists():
        raise FileNotFoundError(f"mapping {m.id}: password file missing: {m.password_file}")
    env = os.environ.copy()
    env["RCLONE_CONFIG"] = str(RCLONE_CONFIG)
    env["RESTIC_PASSWORD_FILE"] = str(m.password_file)
    repo = f"rclone:{m.destination}"
    log.info("[check-remote backup] %s", repo)
    subprocess.run(["restic", "-r", repo, "check"], env=env, check=True)


def cmd_check_remote(args) -> None:
    _, mappings = load_config()
    by_id = {m.id: m for m in mappings}
    if args.id:
        if args.id not in by_id:
            log.error("unknown mapping id: %s", args.id)
            log.error("available: %s", ", ".join(sorted(by_id)))
            sys.exit(2)
        targets = [by_id[args.id]]
    else:
        targets = mappings

    failed: list[str] = []
    for m in targets:
        try:
            if m.mode == "sync":
                _check_remote_sync(m)
            elif m.mode == "backup":
                _check_remote_backup(m)
            else:
                log.error("%s: cannot check mode %s", m.id, m.mode)
                failed.append(m.id)
                continue
            log.info("%s: OK", m.id)
        except subprocess.CalledProcessError as e:
            log.error("%s: check failed (exit %d)", m.id, e.returncode)
            failed.append(m.id)
        except Exception as e:
            log.error("%s: check error: %s", m.id, e)
            failed.append(m.id)

    print(f"\ncheck-remote summary: {len(targets) - len(failed)} ok, {len(failed)} failed")
    if failed:
        print(f"failed: {', '.join(failed)}")
        sys.exit(1)


# ---------- metrics ----------

def _render_metrics(mappings: list[Mapping]) -> str:
    lines: list[str] = []
    lines.append("# HELP cloudsync_last_run_timestamp_seconds Unix epoch of last run start; 0 if never")
    lines.append("# TYPE cloudsync_last_run_timestamp_seconds gauge")
    for m in mappings:
        ts = _parse_iso(_read_state(m.id, "last-run"))
        val = int(ts.timestamp()) if ts else 0
        lines.append(
            f'cloudsync_last_run_timestamp_seconds{{id="{m.id}",mode="{m.mode}"}} {val}'
        )
    lines.append("# HELP cloudsync_last_success_timestamp_seconds Unix epoch of last successful run; 0 if never")
    lines.append("# TYPE cloudsync_last_success_timestamp_seconds gauge")
    for m in mappings:
        ts = _parse_iso(_read_state(m.id, "last-success"))
        val = int(ts.timestamp()) if ts else 0
        lines.append(
            f'cloudsync_last_success_timestamp_seconds{{id="{m.id}",mode="{m.mode}"}} {val}'
        )
    lines.append("# HELP cloudsync_last_failure_timestamp_seconds Unix epoch of last failed run; 0 if never")
    lines.append("# TYPE cloudsync_last_failure_timestamp_seconds gauge")
    for m in mappings:
        raw = _read_state(m.id, "last-error")
        ts = _parse_iso(raw) if raw else None
        val = int(ts.timestamp()) if ts else 0
        lines.append(
            f'cloudsync_last_failure_timestamp_seconds{{id="{m.id}",mode="{m.mode}"}} {val}'
        )
    lines.append("# HELP cloudsync_consecutive_failures Consecutive failed attempts since last success")
    lines.append("# TYPE cloudsync_consecutive_failures gauge")
    for m in mappings:
        raw = _read_state(m.id, "attempts")
        val = int(raw) if raw and raw.isdigit() else 0
        lines.append(
            f'cloudsync_consecutive_failures{{id="{m.id}",mode="{m.mode}"}} {val}'
        )
    lines.append("# HELP cloudsync_mapping_info Labels describing each mapping")
    lines.append("# TYPE cloudsync_mapping_info gauge")
    for m in mappings:
        lines.append(
            f'cloudsync_mapping_info{{id="{m.id}",mode="{m.mode}",'
            f'trigger="{m.trigger}"}} 1'
        )
    return "\n".join(lines) + "\n"


def cmd_metrics(args) -> None:
    _, mappings = load_config()
    text = _render_metrics(mappings)
    if args.output:
        out = Path(args.output)
        out.parent.mkdir(parents=True, exist_ok=True)
        with tempfile.NamedTemporaryFile(
            mode="w", dir=str(out.parent), prefix=f".{out.name}.", delete=False,
        ) as tmp:
            tmp.write(text)
            tmp.flush()
            os.fsync(tmp.fileno())
            tmp_path = Path(tmp.name)
        os.replace(tmp_path, out)
    else:
        sys.stdout.write(text)


def _validate_schedule(expr: str) -> Optional[str]:
    """Return None if valid, else an error string. Best-effort using systemd-analyze."""
    if not shutil.which("systemd-analyze"):
        return None  # can't validate, don't block
    res = subprocess.run(
        ["systemd-analyze", "calendar", expr],
        capture_output=True, text=True,
    )
    if res.returncode != 0:
        return (res.stderr or res.stdout).strip() or "invalid OnCalendar expression"
    return None


def cmd_check(args) -> None:
    try:
        _, mappings = load_config()
    except ConfigError as e:
        log.error("config invalid: %s", e)
        sys.exit(1)
    except Exception as e:
        log.error("config invalid: %s", e)
        sys.exit(1)

    ok = True
    ids_seen: set[str] = set()
    for m in mappings:
        if m.id in ids_seen:
            log.error("duplicate id: %s", m.id)
            ok = False
        ids_seen.add(m.id)
        if not m.source.exists():
            log.warning("%s: source does not exist: %s", m.id, m.source)
        if m.mode not in ("sync", "backup"):
            log.error("%s: invalid mode: %s", m.id, m.mode)
            ok = False
        if m.trigger not in ("realtime", "scheduled", "both"):
            log.error("%s: invalid trigger: %s", m.id, m.trigger)
            ok = False
        if m.trigger in ("scheduled", "both"):
            err = _validate_schedule(m.schedule)
            if err:
                log.error("%s: invalid schedule %r: %s", m.id, m.schedule, err)
                ok = False
        if m.mode == "backup":
            if not m.password_file:
                log.error("%s: backup mode requires password_file", m.id)
                ok = False
            elif not m.password_file.exists():
                log.warning("%s: password file missing: %s", m.id, m.password_file)
            else:
                mode = m.password_file.stat().st_mode & 0o777
                if mode & (stat.S_IRWXG | stat.S_IRWXO):
                    log.error(
                        "%s: password file %s has insecure mode %04o (should be 0400 or 0600)",
                        m.id, m.password_file, mode,
                    )
                    ok = False

    for tool in ("rclone",):
        if not shutil.which(tool):
            log.error("required tool not found in PATH: %s", tool)
            ok = False
    if any(m.mode == "backup" for m in mappings) and not shutil.which("restic"):
        log.error("backup mappings present but restic not found in PATH")
        ok = False

    if not RCLONE_CONFIG.exists():
        log.warning("rclone config not found: %s", RCLONE_CONFIG)

    print(f"{len(mappings)} mappings loaded ({len(ids_seen)} unique ids)")
    sys.exit(0 if ok else 1)


# ---------- systemd unit generation ----------

SERVICE_TEMPLATE = """\
[Unit]
Description=Cloudsync ({mode}) for {id}: {source} -> {destination}
After=network-online.target
Wants=network-online.target
ConditionPathExists={source}
OnFailure=cloudsync-failure@%n.service

[Service]
Type=oneshot
ExecStart=/usr/local/bin/cloudsync run {id}
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=5
SyslogIdentifier=cloudsync-{id}
TimeoutStartSec={timeout}
RuntimeDirectory=cloudsync
RuntimeDirectoryPreserve=yes
NoNewPrivileges=true
ProtectSystem=strict
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
PrivateTmp=true
ReadWritePaths=/etc/cloudsync /run/cloudsync /var/lib/cloudsync /root/.cache/rclone /root/.cache/restic
"""

TIMER_TEMPLATE = """\
[Unit]
Description=Cloudsync scheduled timer for {id}

[Timer]
OnCalendar={oncalendar}
Persistent=true
RandomizedDelaySec=5min
Unit=cloudsync-{id}.service

[Install]
WantedBy=timers.target
"""

REALTIME_SERVICE_TEMPLATE = """\
[Unit]
Description=Cloudsync realtime (debounced) run for {id}
After=network-online.target
Wants=network-online.target
ConditionPathExists={source}
OnFailure=cloudsync-failure@%n.service

[Service]
Type=oneshot
Environment=CLOUDSYNC_DEBOUNCE={debounce}
ExecStart=/usr/local/bin/cloudsync-realtime-tick {id}
SyslogIdentifier=cloudsync-realtime-{id}
TimeoutStartSec={timeout}
RuntimeDirectory=cloudsync
RuntimeDirectoryPreserve=yes
NoNewPrivileges=true
ProtectSystem=strict
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
PrivateTmp=true
ReadWritePaths=/etc/cloudsync /run/cloudsync /var/lib/cloudsync /root/.cache/rclone /root/.cache/restic
"""

REALTIME_PATH_TEMPLATE = """\
[Unit]
Description=Cloudsync realtime watcher for {id}: {source}

[Path]
PathChanged={source}
PathModified={source}
Unit=cloudsync-realtime-{id}.service

[Install]
WantedBy=multi-user.target
"""

FAILURE_TEMPLATE_UNIT = """\
[Unit]
Description=Cloudsync failure notifier for %i
# This is a template. Override with `systemctl edit cloudsync-failure@.service`
# to plug in your notifier of choice (ntfy, healthchecks, email, etc.).
# Example drop-in (/etc/systemd/system/cloudsync-failure@.service.d/override.conf):
#   [Service]
#   ExecStart=
#   ExecStart=/usr/bin/curl -fsS -m 10 https://hc-ping.com/<uuid>/fail

[Service]
Type=oneshot
ExecStart=/bin/true
"""


UNIT_KINDS = {
    "service":          "cloudsync-{id}.service",
    "timer":            "cloudsync-{id}.timer",
    "realtime-service": "cloudsync-realtime-{id}.service",
    "realtime-path":    "cloudsync-realtime-{id}.path",
}


def systemd_filename(kind: str, mapping_id: str) -> Path:
    return SYSTEMD_DIR / UNIT_KINDS[kind].format(id=mapping_id)


def _existing_cloudsync_units() -> list[Path]:
    if not SYSTEMD_DIR.exists():
        return []
    patterns = (
        "cloudsync-*.service", "cloudsync-*.timer",
        "cloudsync-realtime-*.service", "cloudsync-realtime-*.path",
    )
    found: set[Path] = set()
    for pat in patterns:
        found.update(SYSTEMD_DIR.glob(pat))
    # Exclude the shared failure template unit — it's not per-mapping.
    found.discard(SYSTEMD_DIR / "cloudsync-failure@.service")
    return sorted(found)


def _expected_units(mappings: list[Mapping]) -> set[Path]:
    expected: set[Path] = set()
    for m in mappings:
        expected.add(systemd_filename("service", m.id))
        if m.trigger in ("scheduled", "both"):
            expected.add(systemd_filename("timer", m.id))
        if m.trigger in ("realtime", "both"):
            expected.add(systemd_filename("realtime-service", m.id))
            expected.add(systemd_filename("realtime-path", m.id))
    return expected


def _unit_name_for_systemctl(path: Path) -> str:
    return path.name


def _disable_and_remove(path: Path, dry_run: bool) -> None:
    unit = _unit_name_for_systemctl(path)
    # Only .timer and .path units are enabled; disabling a .service is a no-op but harmless.
    if dry_run:
        print(f"  would disable and remove: {unit}")
        return
    log.info("disabling %s", unit)
    subprocess.run(["systemctl", "disable", "--now", unit], check=False)
    try:
        path.unlink()
        log.info("removed %s", path)
    except FileNotFoundError:
        pass


def cmd_setup_systemd(args) -> None:
    try:
        _, mappings = load_config()
    except ConfigError as e:
        log.error("config invalid: %s", e)
        sys.exit(1)

    if os.geteuid() != 0 and not args.dry_run:
        log.error("setup-systemd must be run as root (or pass --dry-run)")
        sys.exit(2)

    written: list[Path] = []
    enabled_units: list[str] = []

    for m in mappings:
        scheduled = m.trigger in ("scheduled", "both")
        realtime = m.trigger in ("realtime", "both")

        svc_path = systemd_filename("service", m.id)
        svc_content = SERVICE_TEMPLATE.format(
            mode=m.mode, id=m.id, source=m.source,
            destination=m.destination, timeout=m.timeout,
        )
        _write(svc_path, svc_content, args.dry_run)
        written.append(svc_path)

        if scheduled:
            timer_path = systemd_filename("timer", m.id)
            timer_content = TIMER_TEMPLATE.format(id=m.id, oncalendar=m.schedule)
            _write(timer_path, timer_content, args.dry_run)
            written.append(timer_path)
            enabled_units.append(f"cloudsync-{m.id}.timer")

        if realtime:
            rsvc_path = systemd_filename("realtime-service", m.id)
            rsvc_content = REALTIME_SERVICE_TEMPLATE.format(
                id=m.id, source=m.source, debounce=m.debounce, timeout=m.timeout,
            )
            _write(rsvc_path, rsvc_content, args.dry_run)
            written.append(rsvc_path)

            rpath_path = systemd_filename("realtime-path", m.id)
            rpath_content = REALTIME_PATH_TEMPLATE.format(id=m.id, source=m.source)
            _write(rpath_path, rpath_content, args.dry_run)
            written.append(rpath_path)
            enabled_units.append(f"cloudsync-realtime-{m.id}.path")

    failure_path = SYSTEMD_DIR / "cloudsync-failure@.service"
    if not failure_path.exists() or args.dry_run:
        _write(failure_path, FAILURE_TEMPLATE_UNIT, args.dry_run)
        if not args.dry_run:
            written.append(failure_path)

    expected = _expected_units(mappings)
    orphans = [p for p in _existing_cloudsync_units() if p not in expected]

    if orphans:
        if args.prune:
            print(f"\nPruning {len(orphans)} orphan unit(s):")
            for p in orphans:
                _disable_and_remove(p, args.dry_run)
        else:
            print(f"\n{len(orphans)} orphan unit file(s) on disk "
                  f"(re-run with --prune to remove):")
            for p in orphans:
                print(f"  {p}")

    print(f"\n{len(written)} unit files {'would be written' if args.dry_run else 'written'}.")

    if not args.dry_run:
        log.info("reloading systemd")
        subprocess.run(["systemctl", "daemon-reload"], check=True)
        for unit in enabled_units:
            log.info("enabling %s", unit)
            subprocess.run(["systemctl", "enable", "--now", unit], check=True)
        print(f"\n{len(enabled_units)} units enabled and started.")
    else:
        print("Units that would be enabled:")
        for unit in enabled_units:
            print(f"  systemctl enable --now {unit}")


def _write(path: Path, content: str, dry_run: bool) -> None:
    if dry_run:
        print(f"\n--- {path} ---\n{content}", end="")
        return
    # Atomic replace so a crashed write can't leave a partial unit file.
    path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile(
        mode="w", dir=str(path.parent), prefix=f".{path.name}.", delete=False,
    ) as tmp:
        tmp.write(content)
        tmp.flush()
        os.fsync(tmp.fileno())
        tmp_path = Path(tmp.name)
    os.replace(tmp_path, path)
    log.info("wrote %s", path)


# ---------- entry point ----------

def main() -> None:
    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s %(levelname)s %(message)s",
    )
    p = argparse.ArgumentParser(prog="cloudsync", description=__doc__.split("\n\n")[0])
    p.add_argument("--version", action="version", version=f"cloudsync {__version__}")
    sub = p.add_subparsers(dest="command", required=True)

    sp = sub.add_parser("run", help="run a single mapping by id")
    sp.add_argument("id")
    sp.set_defaults(func=cmd_run)

    sp = sub.add_parser("run-all", help="run all mappings")
    sp.set_defaults(func=cmd_run_all)

    sp = sub.add_parser("list", help="list configured mappings")
    sp.set_defaults(func=cmd_list)

    sp = sub.add_parser("check", help="validate config and dependencies")
    sp.set_defaults(func=cmd_check)

    sp = sub.add_parser("status", help="report last-run / last-success / next-fire per mapping")
    sp.set_defaults(func=cmd_status)

    sp = sub.add_parser(
        "check-remote",
        help="verify remote integrity (restic check for backup, rclone check for sync)",
    )
    sp.add_argument("id", nargs="?", default=None,
                    help="mapping id to check; omit to check all")
    sp.set_defaults(func=cmd_check_remote)

    sp = sub.add_parser(
        "metrics",
        help="emit Prometheus-format metrics (for node_exporter textfile collector)",
    )
    sp.add_argument(
        "--output", "-o", default=None,
        help="write to this file atomically instead of stdout "
             "(e.g. /var/lib/node_exporter/textfile/cloudsync.prom)",
    )
    sp.set_defaults(func=cmd_metrics)

    sp = sub.add_parser("setup-systemd", help="generate and enable systemd units from config")
    sp.add_argument("--dry-run", action="store_true", help="print units without writing")
    sp.add_argument("--prune", action="store_true",
                    help="disable and remove orphan units for ids no longer in config")
    sp.set_defaults(func=cmd_setup_systemd)

    args = p.parse_args()
    try:
        args.func(args)
    except ConfigError as e:
        log.error("config error: %s", e)
        sys.exit(1)


if __name__ == "__main__":
    main()
